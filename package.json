{
  "name": "ts-mcp-starter",
  "version": "0.1.0",
  "description": "A Bun + TypeScript MCP server demo that simulates weather queries.",
  "type": "module",
  "module": "src/index.ts",
  "private": true,
  "scripts": {
    "start": "bun run src/index.ts",
    "start:http": "bun run src/index.ts --http",
    "start:both": "bun run src/index.ts --both",
    "test": "bun test",
    "dev": "bun --watch run src/index.ts",
    "dev:http": "bun --watch run src/index.ts --http",
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --minify",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write ."
  },
  "bin": {
    "ts-mcp-starter": "src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
